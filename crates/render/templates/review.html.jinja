<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <title>{{ paper.title }} — GrokRxiv Review</title>
  <meta name="generator" content="grokrxiv-render">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <!-- KaTeX is rendered client-side; math is kept as \( ... \) and \[ ... \] delimiters. -->
  <style>
    :root { color-scheme: light dark; --fg: #111; --muted: #555; --bg: #fff;
            --accent: #1f6feb; --border: #d0d7de; --banner: #fff3cd; --banner-fg: #664d03; }
    @media (prefers-color-scheme: dark) {
      :root { --fg: #e6edf3; --muted: #8b949e; --bg: #0d1117; --accent: #58a6ff;
              --border: #30363d; --banner: #3a2f0b; --banner-fg: #f1c453; }
    }
    body { font: 16px/1.55 -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
           color: var(--fg); background: var(--bg); max-width: 820px;
           margin: 0 auto; padding: 24px; }
    h1 { font-size: 1.7rem; line-height: 1.25; margin: 0 0 0.5rem; }
    h2 { font-size: 1.2rem; margin-top: 2rem; border-bottom: 1px solid var(--border); padding-bottom: .25rem; }
    .muted { color: var(--muted); }
    .disclaimer { background: var(--banner); color: var(--banner-fg); border: 1px solid var(--border);
                  padding: .75rem 1rem; border-radius: 6px; margin: 0 0 1.5rem; font-weight: 600; }
    .footer-disclaimer { margin-top: 2.5rem; padding-top: 1rem; border-top: 1px solid var(--border);
                         color: var(--muted); font-size: .9rem; }
    .brand { font-weight: 700; color: var(--accent); }
    details { border: 1px solid var(--border); border-radius: 6px; padding: .75rem 1rem; margin: .5rem 0; }
    details > summary { cursor: pointer; font-weight: 600; }
    .meta-link { font-size: .9rem; }
    ul { padding-left: 1.25rem; }
    code, pre { font-family: ui-monospace, SFMono-Regular, Menlo, monospace; }
    .agent-grid { display: grid; gap: .5rem; }
    .badge { display: inline-block; padding: 2px 8px; border-radius: 999px;
             background: var(--border); color: var(--fg); font-size: .8rem; }
    .badge.pass { background: #1f883d; color: #fff; }
    .badge.warn { background: #bf8700; color: #fff; }
    .badge.fail { background: #cf222e; color: #fff; }
  </style>
</head>
<body>
  <header>
    <h1>{{ paper.title }}</h1>
    <p class="muted">
      <span class="brand">GrokRxiv</span> review of
      {% if source_url %}<a class="meta-link" href="{{ source_url|safe }}">{{ source_label }}</a>{% else %}<span class="meta-link">{{ source_label }}</span>{% endif %}
      {% if paper.field %} · <span>{{ paper.field }}</span>{% endif %}
    </p>
    <p class="muted">
      {% for a in paper.authors %}{{ a.name }}{% if not loop.last %}, {% endif %}{% endfor %}
    </p>
  </header>

  <section>
    <h2>TL;DR</h2>
    <p>{{ meta.summary }}</p>
    <p class="muted">Recommendation: <strong>{{ recommendation_label }}</strong> · Confidence: {{ confidence_pct }}%</p>
  </section>

  <section>
    <h2>Strengths</h2>
    <ul>
      {% for s in meta.strengths %}<li>{{ s }}</li>{% endfor %}
    </ul>
  </section>

  <section>
    <h2>Weaknesses</h2>
    <ul>
      {% for w in meta.weaknesses %}<li>{{ w }}</li>{% endfor %}
    </ul>
  </section>

  <section>
    <h2>Open Questions</h2>
    <ul>
      {% for q in meta.questions %}<li>{{ q }}</li>{% endfor %}
    </ul>
  </section>

  <section>
    <h2>Per-Agent Reviews</h2>
    <div class="agent-grid">
      {% for agent in agents %}
      <details>
        <summary>
          {{ agent.role }} — <span class="muted">{{ agent.model }}</span>
          <span class="badge {{ agent.verifier_status }}">{{ agent.verifier_status }}</span>
        </summary>
        <pre>{{ agent.output_pretty }}</pre>
      </details>
      {% endfor %}
    </div>
  </section>

  <!-- corrections rendered from corrections table; empty on first publish -->
  <section>
    <h2>Corrections</h2>
    <p class="muted">No corrections have been recorded.</p>
  </section>

  <section>
    <h2>Bibliography</h2>
    {% if paper.bibliography %}
    <ol>
      {% for c in paper.bibliography %}
        <li>
          {{ c.raw }}
          {% if c.doi %}<a href="https://doi.org/{{ c.doi }}">doi:{{ c.doi }}</a>{% endif %}
          {% if c.arxiv_id %}<a href="https://arxiv.org/abs/{{ c.arxiv_id }}">arXiv:{{ c.arxiv_id }}</a>{% endif %}
        </li>
      {% endfor %}
    </ol>
    {% else %}
    <p class="muted">No bibliography extracted.</p>
    {% endif %}
  </section>

  <footer class="footer-disclaimer">
    <p class="muted">Rendered by <span class="brand">GrokRxiv</span>. Source: {% if source_url %}<a href="{{ source_url|safe }}">{{ source_label }}</a>{% else %}<span>{{ source_label }}</span>{% endif %}.</p>
  </footer>
</body>
</html>
