# AgentHero root env selector.
#
# Copy this file to `.env`. App-specific env files live with each DAGOps app.
# For GrokRxiv local development:
#
#   cp .env.example .env
#   cd agenthero/apps/grokrxiv/env
#   for f in .env_*.example; do cp "$f" "${f%.example}"; done
#
# The AgentHero CLI loads `.env` first, then each file listed here. Relative
# entries resolve from this file's directory. Values already present in the
# shell or root `.env` win over included files.
AGENTHERO_ENV_FILES=agenthero/apps/grokrxiv/env/.env_core,agenthero/apps/grokrxiv/env/.env_ingest,agenthero/apps/grokrxiv/env/.env_extract,agenthero/apps/grokrxiv/env/.env_review,agenthero/apps/grokrxiv/env/.env_publish,agenthero/apps/grokrxiv/env/.env_web,agenthero/apps/grokrxiv/env/.env_billing,agenthero/apps/grokrxiv/env/.env_dev

# Runtime artifacts are app-scoped under this root.
AGENTHERO_ARTIFACTS_DIR=.agenthero/artifacts
