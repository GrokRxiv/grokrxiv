# GrokRxiv root env selector.
#
# Copy this file to `.env`, then copy each purpose file listed by
# `GROKRXIV_ENV_FILES` below. Trim the list for narrower processes.
#
#   cp .env.example .env
#   cp .env_core.example .env_core
#   cp .env_ingest.example .env_ingest
#   cp .env_extract.example .env_extract
#   cp .env_review.example .env_review
#   cp .env_publish.example .env_publish
#   cp .env_web.example .env_web
#   cp .env_billing.example .env_billing
#   cp .env_dev.example .env_dev
#
# The Rust CLI/orchestrator loads `.env` first, then loads each file named
# below. Values already present in the shell or root `.env` win over included
# files. Trim this list for narrower processes.
GROKRXIV_ENV_FILES=.env_core,.env_ingest,.env_extract,.env_review,.env_publish,.env_web,.env_billing,.env_dev
