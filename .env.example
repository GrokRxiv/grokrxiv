SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImV4cCI6MTk4MzgxMjk5Nn0.EGIM96RAZx35lJzdJsyH-qQwv8Hdp7fsn3W0YpN81IU
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# Supabase Auth SMTP for hosted/staging/production magic links.
# Local `supabase start` is configured in supabase/config.toml to route SMTP
# to the Supabase Mailpit container at http://127.0.0.1:54324.
SMTP_HOST=smtp.mailgun.org
SMTP_PORT=587
SMTP_USER=postmaster@appmail.magnetonlabs.com
SMTP_PASS=
SMTP_ADMIN_EMAIL=no-reply@appmail.magnetonlabs.com
SMTP_SENDER_NAME=GrokRxiv

# LLM providers
ANTHROPIC_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=
OPENAI_API_KEY=
VLLM_BASE_URL=http://localhost:8000/v1
VLLM_API_KEY=

# GitHub publisher
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GROKRXIV_REVIEWS_REPO=GrokRxiv/grokrxiv-reviews
GROKRXIV_PUBLIC_REVIEWS_REPO=GrokRxiv/grokrxiv-reviews
GROKRXIV_PRIVATE_REVIEWS_REPO=GrokRxiv/grokrxiv-private-reviews
GROKRXIV_REVIEWS_DEPLOY_KEY_PATH=

# Orchestrator
ORCHESTRATOR_BIND=0.0.0.0:8080
ORCHESTRATOR_URL=http://localhost:8080
RUST_LOG=info,orchestrator=debug
GROKRXIV_RUNNER=cli
GROKRXIV_EXTRACTOR=cli
GROKRXIV_ALLOW_PROVIDER_API=0
GROKRXIV_SUMMARY_MODEL=claude-haiku-4-5-20251001
GROKRXIV_TECHNICAL_CORRECTNESS_MODEL=claude-opus-4-7
GROKRXIV_NOVELTY_MODEL=gemini-3-flash-preview
GROKRXIV_REPRODUCIBILITY_MODEL=gpt-5.5
GROKRXIV_CITATION_MODEL=gemini-3-flash-preview
GROKRXIV_META_REVIEWER_MODEL=claude-sonnet-4-6
GROKRXIV_REVIEW_CONCURRENCY=1
GROKRXIV_FREE_REVIEW_LIMIT=3
GROKRXIV_DAILY_FULL_REVIEW_LIMIT=
GROKRXIV_MONTHLY_FULL_REVIEW_LIMIT=
GROKRXIV_MAX_COST_USD=
# Pandoc is the default TeX -> Markdown converter. LaTeXML semantic AST
# enrichment is opt-in because it can be slow on large arXiv source bundles.
# GROKRXIV_PANDOC_BIN=/path/to/pandoc
# GROKRXIV_DOCKER_INSTALL_PANDOC=1
# GROKRXIV_TEX_ENABLE_LATEXML=1
# GROKRXIV_FORCE_AGENT_EXTRACTION=1

# Web app
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Prefer Apple Silicon native web image locally; use linux/amd64 if an image has
# no ARM build and must run through Docker Desktop emulation.
GROKRXIV_WEB_PLATFORM=linux/arm64
# Browser-facing Supabase URL. Do not set this to host.docker.internal.
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
# Server-side Docker URL for the web container. Leave unset outside Docker.
SUPABASE_INTERNAL_URL=http://host.docker.internal:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMblYTn_I0
ORCHESTRATOR_INTERNAL_URL=http://localhost:8080
REVALIDATE_SECRET=

# arXiv
ARXIV_USER_AGENT=GrokRxiv/0.1 (mailto:mlong168@gmail.com)

# Storage SDK (Tier 1 — grokrxiv-data Git repo; Tier 2 — Supabase Object Storage).
# Bucket names are hardcoded in crates/storage (raw-pdfs, raw-source,
# extracted-markdown, extracted-json, embeddings, review-artifacts). Switching
# between local supabase and Supabase Cloud is purely a SUPABASE_URL +
# SUPABASE_SERVICE_ROLE_KEY flip.
GROKRXIV_DATA_REPO_PATH=/Users/mlong/Documents/Development/grokrxiv-data
GROKRXIV_DATA_REMOTE=git@github.com:GrokRxiv/grokrxiv-data.git
