# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=postgresql://postgres:postgres@localhost:54322/postgres

# LLM providers
ANTHROPIC_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=
OPENAI_API_KEY=
VLLM_BASE_URL=http://localhost:8000/v1
VLLM_API_KEY=

# GitHub publisher
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GROKRXIV_REVIEWS_REPO=GrokRxiv/reviews
GROKRXIV_REVIEWS_DEPLOY_KEY_PATH=

# Orchestrator
ORCHESTRATOR_BIND=0.0.0.0:8080
ORCHESTRATOR_URL=http://localhost:8080
RUST_LOG=info,orchestrator=debug

# Web app
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
ORCHESTRATOR_INTERNAL_URL=http://localhost:8080
REVALIDATE_SECRET=

# arXiv
ARXIV_USER_AGENT=GrokRxiv/0.1 (mailto:mlong168@gmail.com)

# Storage SDK (Tier 1 — grokrxiv-data Git repo; Tier 2 — Supabase Object Storage).
# Bucket names are hardcoded in crates/storage (raw-pdfs, raw-source,
# extracted-markdown, extracted-json, embeddings, review-artifacts). Switching
# between local supabase and Supabase Cloud is purely a SUPABASE_URL +
# SUPABASE_SERVICE_ROLE_KEY flip.
GROKRXIV_DATA_REPO_PATH=/Users/mlong/Documents/Development/grokrxiv-data
GROKRXIV_DATA_REMOTE=git@github.com:GrokRxiv/grokrxiv-data.git
