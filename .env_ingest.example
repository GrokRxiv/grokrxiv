# Source acquisition, storage, and ingest scheduling.

GROKRXIV_ARXIV_BASE=https://export.arxiv.org/api/query
GROKRXIV_CROSSREF_BASE=https://api.crossref.org/works

# Storage SDK (Tier 1: grokrxiv-data Git repo; Tier 2: Supabase Object Storage).
GROKRXIV_DATA_REPO_PATH=/Users/mlong/Documents/Development/grokrxiv-data
GROKRXIV_DATA_REPO_REMOTE=git@github.com:GrokRxiv/grokrxiv-data.git

# Docker-only data repo mount controls.
GROKRXIV_DOCKER_DATA_REPO_SOURCE=../grokrxiv-data
GROKRXIV_DOCKER_DATA_REPO_PATH=/workspace/grokrxiv-data

# Scheduler controls.
INGEST_CATEGORIES=
INGEST_DAILY_AT_UTC=
INGEST_BACKFILL_FROM=
AUTO_REVIEW_FROM=
GROKRXIV_DISABLE_SCHEDULER=0

# Ingest runtime controls.
GROKRXIV_INGEST_NO_CACHE=0
GROKRXIV_INGEST_SKIP_STAGES=
GROKRXIV_DRY_RUN_STORAGE=0
