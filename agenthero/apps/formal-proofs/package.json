{
  "name": "@agenthero/formal-proofs",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "adapter": "node dist/adapter.js",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "rm -rf dist-test && tsc -p tsconfig.test.json && node --test dist-test/test/*.test.js"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "tsx": "^4.20.0",
    "typescript": "^5.6.3"
  }
}
