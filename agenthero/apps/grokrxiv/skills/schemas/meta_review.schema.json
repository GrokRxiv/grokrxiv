{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://grokrxiv.org/schemas/meta_review.schema.json",
  "title": "MetaReview",
  "description": "Final synthesized review combining the five specialist outputs. Mirrors agenthero/apps/grokrxiv/web/lib/types.ts::MetaReview.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "summary": { "type": "string" },
    "strengths": {
      "type": "array",
      "items": { "type": "string" }
    },
    "weaknesses": {
      "type": "array",
      "items": { "type": "string" }
    },
    "questions": {
      "type": "array",
      "items": { "type": "string" }
    },
    "revision_targets": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string" },
          "weakness_index": { "type": "integer", "minimum": 0 },
          "source_role": {
            "type": ["string", "null"]
          },
          "target_kind": {
            "type": "string",
            "enum": [
              "paper_tex",
              "paper_pdf",
              "code",
              "data",
              "bibliography",
              "review_text",
              "unknown"
            ]
          },
          "source_path": { "type": ["string", "null"] },
          "locator": { "type": ["string", "null"] },
          "evidence": { "type": ["string", "null"] },
          "required_update": { "type": "string" },
          "verification_check": { "type": "string" },
          "status": {
            "type": "string",
            "enum": ["open", "addressed", "still_open", "superseded", "unknown"]
          }
        },
        "required": [
          "id",
          "weakness_index",
          "source_role",
          "target_kind",
          "source_path",
          "locator",
          "evidence",
          "required_update",
          "verification_check",
          "status"
        ]
      }
    },
    "recommendation": {
      "type": "string",
      "enum": ["accept", "minor_revision", "major_revision", "reject"]
    },
    "confidence": { "type": "number" }
  },
  "required": [
    "summary",
    "strengths",
    "weaknesses",
    "questions",
    "recommendation",
    "confidence"
  ]
}
