{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "agenthero/apps/grokrxiv/infra/docker/orchestrator.Dockerfile"
  },
  "deploy": {
    "startCommand": "/usr/local/bin/orchestrator",
    "healthcheckPath": "/healthz",
    "healthcheckTimeout": 30,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 5,
    "numReplicas": 1
  }
}
