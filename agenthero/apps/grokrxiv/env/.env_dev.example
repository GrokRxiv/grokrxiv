# Local development, Docker, diagnostics, and safety switches.

GROKRXIV_DOCKER_INSTALL_AGENT_CLIS=1
GROKRXIV_DOCKER_INSTALL_PANDOC=1

# Prefer Apple Silicon native images locally; use linux/amd64 if an
# image/dependency has no ARM build and must run through Docker Desktop
# emulation.
GROKRXIV_ORCHESTRATOR_PLATFORM=linux/arm64
GROKRXIV_WEB_PLATFORM=linux/arm64

# App-root overrides are mainly for packaged/container runtimes. Local source
# checkouts normally use the default agenthero/apps directory.
AGENTHERO_APPS_ROOT=agenthero/apps
AGENTHERO_ADAPTER_BIN_DIR=
AGENTHERO_APP_BIN_DIR=
AGENTHERO_ADAPTER_CWD=
AGENTHERO_ADAPTER_TIMEOUT_SECS=7200
AGENTHERO_ADAPTER_OUTPUT_LIMIT_BYTES=8388608
AGENTHERO_ALLOW_ADAPTER_FALLBACK=1
GROKRXIV_APP_BIN=
# AGENTHERO_AGENTS_DIR=/etc/agenthero/apps/grokrxiv/agents
# AGENTHERO_DAGS_DIR=/etc/agenthero/apps/grokrxiv/dags

GROKRXIV_SUPERVISOR_QUEUE_CAPACITY=4096
GROKRXIV_SUPERVISOR_WORKERS=64
GROKRXIV_NO_CACHE=0
AGENTHERO_OFFLINE=0
GROKRXIV_STATUS=0
GROKRXIV_DEBUG_PROMPT_DIR=
GROKRXIV_DOCTOR_REQUIRE_RUNNER=0
# AGENTHERO_MODERATOR=operator@example.com
AGENTHERO_MODE=review_only
AGENTHERO_SANDBOX=none

# Docker compose intentionally uses these optional vars, not provider API keys
# from the host shell, unless API-backend tests explicitly opt in.
GROKRXIV_DOCKER_ANTHROPIC_API_KEY=
GROKRXIV_DOCKER_OPENAI_API_KEY=
GROKRXIV_DOCKER_GOOGLE_GENERATIVE_AI_API_KEY=
