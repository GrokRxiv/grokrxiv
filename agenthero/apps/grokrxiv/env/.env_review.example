# Review DAG LLM providers, runners, models, and verifier limits.

ANTHROPIC_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=
OPENAI_API_KEY=
# The verifier throttles Semantic Scholar calls to stay under 1 request/sec.
SEMANTIC_SCHOLAR_API_KEY=
VLLM_BASE_URL=http://localhost:8000/v1
VLLM_API_KEY=

AGENTHERO_RUNNER=cli
AGENTHERO_ALLOW_PROVIDER_API=0
GROKRXIV_REQUIRE_CLI_AUTH=1
GROKRXIV_GEMINI_AUTH_TYPE=oauth-personal

# Agent YAML files own default provider/model/runner/timeout choices.
# Uncomment only for local overrides:
# GROKRXIV_SUMMARY_MODEL=claude-haiku-4-5
# GROKRXIV_TECHNICAL_CORRECTNESS_MODEL=claude-opus-4-7
# GROKRXIV_NOVELTY_PROVIDER=claude
# GROKRXIV_NOVELTY_MODEL=sonnet[1m]
# GROKRXIV_REPRODUCIBILITY_MODEL=gpt-5.5
# GROKRXIV_CITATION_PROVIDER=claude
# GROKRXIV_CITATION_MODEL=sonnet[1m]
# GROKRXIV_META_REVIEWER_MODEL=sonnet[1m]

# Uncomment only to override YAML timeouts:
# GROKRXIV_SUMMARY_TIMEOUT_SECS=90
# GROKRXIV_TECHNICAL_CORRECTNESS_TIMEOUT_SECS=600
# GROKRXIV_NOVELTY_TIMEOUT_SECS=360
# GROKRXIV_REPRODUCIBILITY_TIMEOUT_SECS=240
# GROKRXIV_CITATION_TIMEOUT_SECS=900
# GROKRXIV_META_REVIEWER_TIMEOUT_SECS=300

# Deterministic citation API resolver controls. These govern Crossref/arXiv/DOI
# and fallback bibliographic APIs, not the Sonnet citation critic timeout above.
GROKRXIV_CITATION_VERIFY_BUDGET_SECS=600
GROKRXIV_CITATION_ENTRY_CONCURRENCY=16
GROKRXIV_CITATION_REQUEST_TIMEOUT_SECS=15
GROKRXIV_CITATION_PROVIDER_TIMEOUT_SECS=10

GROKRXIV_PREVIEW_PROVIDER=gemini
GROKRXIV_PREVIEW_MODEL=gemini-3-flash-preview
GROKRXIV_PREVIEW_TIMEOUT_SECS=120
PREVIEW_MODEL=

GROKRXIV_REVIEW_CONCURRENCY=5
GROKRXIV_CITATION_PROMPT_MAX_BIB_ENTRIES=32
AGENTHERO_MAX_COST_USD=

# Formalize / Lean source inventory controls. The MVP default attempts a bounded
# best-effort Lean set; set GROKRXIV_LEAN_MAX_TARGETS=0 for full theorem-level mode.
GROKRXIV_FORMALIZE_SOURCE_CONTEXT_MAX_BLOCKS=240
GROKRXIV_FORMALIZE_SOURCE_CONTEXT_MAX_CHARS=500000
GROKRXIV_FORMALIZE_TRANSCRIPTION_BATCH_ITEMS=1
GROKRXIV_FORMALIZE_TRANSCRIPTION_BATCH_CHARS=30000
GROKRXIV_FORMALIZE_SOURCE_EXTRACTION_TIMEOUT_SECS=1800
GROKRXIV_FORMALIZE_TYPED_IR_PROVIDER=claude
GROKRXIV_FORMALIZE_TYPED_IR_MODEL=sonnet[1m]
GROKRXIV_FORMALIZE_TYPED_IR_TIMEOUT_SECS=300
GROKRXIV_FORMALIZE_TYPED_IR_TIMEOUT_MAX_SECS=1800
GROKRXIV_FORMALIZE_TYPED_IR_BATCH_CONCURRENCY=4
GROKRXIV_FORMALIZE_TYPED_IR_INCLUDE_CONTEXT=0
GROKRXIV_FORMALIZE_TYPED_IR_MAX_ITEMS=8
# Benchmark typed-IR only through `agh app run grokrxiv formalize <review_id>`.
GROKRXIV_FORMALIZE_TYPED_IR_ONLY=0
GROKRXIV_FORMALIZE_QUEUE_AUTOSTART=1
GROKRXIV_LEAN_TARGET_CONCURRENCY=3
GROKRXIV_LEAN_MAX_TARGETS=8
GROKRXIV_LEAN_PROOF_AUTHOR_TIMEOUT_MAX_SECS=1800

# Optional citation verifier grounded fallback for plain-reference residue.
# `GROKRXIV_CITATION_GROUNDED_RESOLVER_URL` points at an app-local resolver
# service. When it is unset, the verifier can call Gemini's Google Search
# grounding API directly if `GOOGLE_GENERATIVE_AI_API_KEY`, `GEMINI_API_KEY`,
# or `GOOGLE_API_KEY` is set.
# GROKRXIV_CITATION_GROUNDED_RESOLVER_URL=http://127.0.0.1:8787/grounded/citation
# GROKRXIV_CITATION_GROUNDED_MODEL=gemini-3-flash-preview
# GROKRXIV_CITATION_GROUNDED_GEMINI_BASE_URL=https://generativelanguage.googleapis.com

# Runner override patterns. Replace CITATION with any role slug in uppercase,
# such as SUMMARY or TECHNICAL_CORRECTNESS.
AGENTHERO_RUNNER_OVERRIDE=
AGENTHERO_RUNNER_OVERRIDE_CITATION=
# Provider/model override patterns. Gemini/agy is available as a backup route,
# for example `GROKRXIV_CITATION_PROVIDER=gemini` plus a current agy model.
AGENTHERO_PROVIDER_OVERRIDE_CITATION=
AGENTHERO_MODEL_OVERRIDE_CITATION=
AGENTHERO_CLAUDE_BIN=claude
AGENTHERO_CODEX_BIN=codex
AGENTHERO_ANTIGRAVITY_BIN=agy
# Optional quota fallback for local CLI runs. Disabled by default; uncomment to
# use Gemini through Antigravity/agy only after the primary CLI reports quota.
# AGENTHERO_CLI_QUOTA_FALLBACK_PROVIDER=gemini
# AGENTHERO_CLI_QUOTA_FALLBACK_MODEL=Gemini 3.5 Flash (Medium)
AGENTHERO_AGH_BIN=agh
# Optional AgentHero runtime state root. Defaults to repo-root .agenthero.
# App-run logs are written under $AGENTHERO_RUNTIME_ROOT/app_runs/.
AGENTHERO_RUNTIME_ROOT=
# Optional structured AgentHero process log destination. Use JSONL for audit pipelines.
AGENTHERO_LOG_FILE=
# Number of local app-run scheduler workers started by `agh serve`.
AGENTHERO_SCHEDULER_WORKERS=1
AGENTHERO_CLI_TIMEOUT_SECS=360

GROKRXIV_HTML_QUALITY_DISABLE=0
GROKRXIV_HTML_QUALITY_MODEL=gpt-5.5
GROKRXIV_HTML_QUALITY_TIMEOUT_SECS=180
