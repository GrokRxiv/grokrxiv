{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "additionalProperties": false,
  "required": ["recommendation", "confidence", "summary", "strengths", "weaknesses"],
  "properties": {
    "recommendation": {
      "type": "string",
      "enum": ["accept", "minor_revision", "major_revision", "reject"]
    },
    "confidence": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 1.0
    },
    "summary": {
      "type": "string"
    },
    "strengths": {
      "type": "array",
      "items": { "type": "string" }
    },
    "weaknesses": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
