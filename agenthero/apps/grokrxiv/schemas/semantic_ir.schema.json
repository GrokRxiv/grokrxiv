{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://grokrxiv.org/schemas/semantic_ir.schema.json",
  "title": "GrokRxiv Mathematical Transcription IR",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "review_id", "source", "definitions", "assumptions", "theorem_candidates", "nonformal_review_claims", "limitations"],
  "properties": {
    "schema_version": { "type": "string", "const": "1.0.0" },
    "review_id": { "type": "string", "minLength": 1 },
    "source": { "type": "string", "enum": ["review_loop/claims.json", "paper_math_sources"] },
    "formalization_policy": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "requires_theorem_level_lean": { "type": "boolean" },
        "lean_verifies_only_formal_math": { "type": "boolean" },
        "reject_metadata_only_models": { "type": "boolean" },
        "reject_review_role_histograms": { "type": "boolean" },
        "forbidden_lean_terms": { "type": "array", "items": { "type": "string" } }
      }
    },
    "paper_math_sources": {
      "type": "object",
      "additionalProperties": true,
      "description": "Paper-derived extraction artifacts used as the formal math source: body.md, equations.json, theorem_graph.json, and semantic_ast.json when available."
    },
    "definitions": { "type": "array", "items": { "$ref": "#/$defs/semantic_item" } },
    "assumptions": { "type": "array", "items": { "$ref": "#/$defs/semantic_item" } },
    "theorem_candidates": {
      "type": "array",
      "items": {
        "allOf": [
          { "$ref": "#/$defs/semantic_item" },
          {
            "type": "object",
            "required": ["formalization_class", "formalization_target"],
            "properties": {
              "formalization_class": { "type": "string", "const": "formal_math" },
              "semantic_category": {
                "type": "string",
                "enum": ["plain_theorem", "equation", "equivalence", "type_safety", "compiler_correctness", "invariant_preservation"]
              },
              "typed_transcription": {
                "type": "object",
                "additionalProperties": false,
                "required": ["status", "source_text", "math_objects", "binders", "assumptions", "conclusion"],
                "properties": {
                  "status": { "type": "string", "enum": ["transcribed", "partial", "needs_haskell_transcription"] },
                  "source_text": { "type": "string" },
                  "math_objects": { "type": "array" },
                  "binders": { "type": "array", "items": { "$ref": "#/$defs/binder" } },
                  "assumptions": { "type": "array", "items": { "$ref": "#/$defs/proposition" } },
                  "conclusion": { "oneOf": [{ "$ref": "#/$defs/proposition" }, { "type": "null" }] }
                }
              },
              "theorem_ir": { "$ref": "#/$defs/theorem_ir" },
              "formalization_target": {
                "type": "object",
                "additionalProperties": false,
                "required": ["lean_declaration", "expected_shape", "proof_policy"],
                "properties": {
                  "lean_declaration": { "type": "string", "minLength": 1 },
                  "expected_shape": { "type": "string", "enum": ["theorem", "lemma"] },
                  "proof_policy": { "type": "string", "const": "closed_proof_no_sorry_admit_axiom" }
                }
              }
            }
          }
        ]
      }
    },
    "nonformal_review_claims": {
      "type": "array",
      "items": {
        "allOf": [
          { "$ref": "#/$defs/semantic_item" },
          {
            "type": "object",
            "required": ["lean_eligible", "reason"],
            "properties": {
              "lean_eligible": { "type": "boolean", "const": false },
              "reason": { "type": "string", "minLength": 1 }
            }
          }
        ]
      }
    },
    "limitations": { "type": "array", "items": { "$ref": "#/$defs/semantic_item" } },
    "knowledge_graph_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["nodes", "edges"],
      "properties": {
        "nodes": { "type": "integer", "minimum": 0 },
        "edges": { "type": "integer", "minimum": 0 }
      }
    }
  },
  "$defs": {
    "semantic_item": {
      "type": "object",
      "additionalProperties": true,
      "required": ["id", "statement", "source_claim_id", "source_span"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "kind": { "type": "string" },
        "statement": { "type": "string", "minLength": 1 },
        "source_claim_id": { "type": "string", "minLength": 1 },
        "source_span": {
          "type": "object",
          "required": ["artifact", "claim_id"],
          "additionalProperties": false,
          "properties": {
            "artifact": { "type": "string", "minLength": 1 },
            "claim_id": { "type": "string", "minLength": 1 },
            "paper_source_id": { "type": "string" },
            "section_id": {},
            "role": { "type": "string" },
            "text_excerpt": { "type": "string" }
          }
        }
      }
    },
    "theorem_ir": {
      "type": "object",
      "additionalProperties": false,
      "required": ["theorem_name", "source_span", "binders", "assumptions", "conclusion"],
      "properties": {
        "theorem_name": { "type": "string", "minLength": 1 },
        "source_span": { "$ref": "#/$defs/semantic_item/properties/source_span" },
        "binders": { "type": "array", "items": { "$ref": "#/$defs/binder" } },
        "assumptions": { "type": "array", "items": { "$ref": "#/$defs/proposition" } },
        "conclusion": { "$ref": "#/$defs/proposition" }
      }
    },
    "binder": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "type"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "type": { "$ref": "#/$defs/math_type" }
      }
    },
    "math_type": {
      "oneOf": [
        { "type": "object", "additionalProperties": false, "required": ["kind"], "properties": { "kind": { "const": "nat" } } },
        { "type": "object", "additionalProperties": false, "required": ["kind"], "properties": { "kind": { "const": "int" } } },
        { "type": "object", "additionalProperties": false, "required": ["kind"], "properties": { "kind": { "const": "real" } } },
        { "type": "object", "additionalProperties": false, "required": ["kind"], "properties": { "kind": { "const": "bool" } } },
        { "type": "object", "additionalProperties": false, "required": ["kind"], "properties": { "kind": { "const": "prop" } } },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "name"],
          "properties": {
            "kind": { "const": "custom" },
            "name": { "type": "string", "minLength": 1 }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "reason"],
          "properties": {
            "kind": { "const": "unknown_type" },
            "reason": { "type": "string", "minLength": 1 }
          }
        }
      ]
    },
    "term": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "name"],
          "properties": {
            "kind": { "const": "var" },
            "name": { "type": "string", "minLength": 1 }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "value"],
          "properties": {
            "kind": { "const": "nat_lit" },
            "value": { "type": "integer", "minimum": 0 }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "lhs", "rhs"],
          "properties": {
            "kind": { "const": "add" },
            "lhs": { "$ref": "#/$defs/term" },
            "rhs": { "$ref": "#/$defs/term" }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "text"],
          "properties": {
            "kind": { "const": "unknown_term" },
            "text": { "type": "string" }
          }
        }
      ]
    },
    "proposition": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "lhs", "rhs"],
          "properties": {
            "kind": { "const": "equals" },
            "lhs": { "$ref": "#/$defs/term" },
            "rhs": { "$ref": "#/$defs/term" }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "text"],
          "properties": {
            "kind": { "const": "unknown_prop" },
            "text": { "type": "string" }
          }
        }
      ]
    }
  }
}
