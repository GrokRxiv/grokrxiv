{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "GrokRxiv Review Loop Code Review",
  "type": "object",
  "additionalProperties": false,
  "required": ["status", "issues", "summary", "confidence"],
  "properties": {
    "status": {
      "type": "string",
      "enum": ["pass", "fail"]
    },
    "issues": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["severity", "message", "line"],
        "properties": {
          "severity": {
            "type": "string",
            "enum": ["blocking", "warning"]
          },
          "message": {
            "type": "string",
            "minLength": 1
          },
          "line": {
            "type": ["integer", "null"],
            "minimum": 1
          }
        }
      }
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    }
  }
}
