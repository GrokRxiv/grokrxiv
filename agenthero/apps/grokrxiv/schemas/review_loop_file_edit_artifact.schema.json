{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "GrokRxiv Review Loop File Edit Artifact",
  "description": "Small audit output for coding agents that edit files in their prepared workdir. The orchestrator reads the edited source files from disk.",
  "type": "object",
  "additionalProperties": false,
  "required": ["language", "filename", "changed", "notes", "confidence"],
  "properties": {
    "language": {
      "type": "string",
      "enum": ["lean", "haskell", "latex"]
    },
    "filename": {
      "type": "string",
      "minLength": 1
    },
    "changed": {
      "type": "boolean"
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    }
  }
}
