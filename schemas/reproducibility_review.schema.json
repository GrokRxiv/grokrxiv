{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://grokrxiv.org/schemas/reproducibility_review.schema.json",
  "title": "ReproducibilityReview",
  "description": "Assessment of code/data availability and the feasibility of reproducing the paper's results.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "code_availability": {
      "type": "string",
      "enum": ["open_source", "available_on_request", "proprietary", "unspecified"]
    },
    "code_url": { "type": ["string", "null"] },
    "data_availability": {
      "type": "string",
      "enum": ["public", "restricted", "synthetic", "private", "unspecified"]
    },
    "data_url": { "type": ["string", "null"] },
    "environment": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "properties": {
        "hardware": { "type": ["string", "null"] },
        "software": { "type": ["string", "null"] },
        "dependencies": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "required": ["hardware", "software", "dependencies"]
    },
    "concerns": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "area": {
            "type": "string",
            "enum": ["code", "data", "compute", "hyperparameters", "evaluation", "other"]
          },
          "description": { "type": "string" },
          "severity": {
            "type": "string",
            "enum": ["info", "minor", "major", "critical"]
          }
        },
        "required": ["area", "description", "severity"]
      }
    },
    "reproducibility_score": { "type": "number" },
    "confidence": { "type": "number" }
  },
  "required": [
    "code_availability",
    "code_url",
    "data_availability",
    "data_url",
    "environment",
    "concerns",
    "reproducibility_score",
    "confidence"
  ]
}
