{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CitationValidationAdjudicator",
  "description": "Agent adjudication output for a deterministic citation-validation report.",
  "type": "object",
  "additionalProperties": false,
  "required": ["verdict", "confidence", "evidence", "remediation_actions"],
  "properties": {
    "verdict": {
      "type": "string",
      "enum": ["verified", "needs_remediation", "failed"]
    },
    "confidence": { "type": "number" },
    "evidence": {
      "type": "array",
      "items": { "type": "string" }
    },
    "remediation_actions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["target", "action", "reason"],
        "properties": {
          "target": { "type": ["string", "null"] },
          "action": { "type": "string" },
          "reason": { "type": "string" }
        }
      }
    }
  }
}
