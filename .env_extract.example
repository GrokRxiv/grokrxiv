# TeX/PDF extraction tools and optional extraction agents.

# Pandoc is the default TeX -> Markdown converter. LaTeXML semantic AST
# enrichment is opt-in because it can be slow on large arXiv source bundles.
GROKRXIV_PANDOC_BIN=pandoc
GROKRXIV_LATEXML_BIN=latexml
GROKRXIV_LATEXMLPOST_BIN=latexmlpost
GROKRXIV_LATEXML_TIMEOUT_SECS=120
GROKRXIV_TEX_ENABLE_LATEXML=0
GROKRXIV_TEX_DISABLE_LATEXML=0

# Current modes:
# - pandoc_enabled: local Pandoc/PDF/Rust extraction path.
# - agent_enabled: extraction LLM tool loops for macros/equations/theorems/citations,
#   with VLM extraction used when no TeX source exists.
GROKRXIV_EXTRACTION_MODE=pandoc_enabled
GROKRXIV_EXTRACTION_MODEL=
GROKRXIV_EXTRACTION_TOOL_FALLBACK=
GROKRXIV_EXTRACTOR=cli
